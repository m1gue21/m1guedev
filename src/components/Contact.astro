---
import { site } from "../data/site";
import { translations } from "../i18n/translations";

const t = translations.en;
---

<section id="contact" class="section-padding relative overflow-hidden">
  <div
    class="absolute inset-0 bg-[radial-gradient(ellipse_at_center,rgba(59,130,246,0.08)_0%,transparent_70%)]"
  ></div>
  <div class="absolute inset-0 grid-pattern opacity-20"></div>

  <div class="container-main relative text-center">
    <div class="reveal">
      <h2
        class="text-4xl font-bold text-gradient md:text-5xl lg:text-6xl"
        data-i18n="contact.title"
      >
        {t.contact.title}
      </h2>
      <p class="mx-auto mt-6 max-w-xl text-lg text-muted" data-i18n="contact.subtitle">
        {t.contact.subtitle}
      </p>
    </div>

    <div class="reveal mt-12 grid grid-cols-1 gap-4 sm:grid-cols-2 lg:flex lg:flex-wrap lg:justify-center lg:gap-6" style="transition-delay: 150ms">
      <a
        href={`mailto:${site.email}`}
        class="contact-btn contact-btn-email glass-card flex items-center justify-center gap-3 px-8 py-5 sm:min-w-[180px]"
        aria-label={`Email: ${site.email}`}
      >
        <img
          src="https://cdn.simpleicons.org/gmail/EA4335"
          alt=""
          aria-hidden="true"
          width="22"
          height="22"
          class="h-5 w-5"
        />
        <span class="font-semibold" data-i18n="contact.email">{t.contact.email}</span>
      </a>

      <a
        href={site.linkedin}
        target="_blank"
        rel="noopener noreferrer"
        class="contact-btn contact-btn-linkedin glass-card flex items-center justify-center gap-3 px-8 py-5 sm:min-w-[180px]"
        aria-label="LinkedIn profile (opens in new tab)"
      >
        <img
          src="/icons/linkedin.svg"
          alt=""
          aria-hidden="true"
          width="22"
          height="22"
          class="h-5 w-5"
        />
        <span class="font-semibold" data-i18n="contact.linkedin">{t.contact.linkedin}</span>
      </a>

      <a
        href={site.whatsapp}
        target="_blank"
        rel="noopener noreferrer"
        class="contact-btn contact-btn-whatsapp glass-card flex items-center justify-center gap-3 px-8 py-5 sm:min-w-[180px]"
        aria-label="WhatsApp +573004940576 (opens in new tab)"
      >
        <img
          src="https://cdn.simpleicons.org/whatsapp/25D366"
          alt=""
          aria-hidden="true"
          width="22"
          height="22"
          class="h-5 w-5"
        />
        <span class="font-semibold" data-i18n="contact.whatsapp">{t.contact.whatsapp}</span>
      </a>

      <a
        href={site.github}
        target="_blank"
        rel="noopener noreferrer"
        class="contact-btn contact-btn-github glass-card flex items-center justify-center gap-3 px-8 py-5 sm:min-w-[180px]"
        aria-label="GitHub profile (opens in new tab)"
      >
        <img
          src="https://cdn.simpleicons.org/github/ffffff"
          alt=""
          aria-hidden="true"
          width="22"
          height="22"
          class="h-5 w-5"
        />
        <span class="font-semibold" data-i18n="contact.github">{t.contact.github}</span>
      </a>
    </div>

    <p class="reveal mt-8 text-sm text-text-muted" data-i18n="contact.response" style="transition-delay: 250ms">
      {t.contact.response}
    </p>
  </div>
</section>
