---
import { site } from "../data/site";
import ParticleMesh from "./ParticleMesh.astro";
import Typewriter from "./Typewriter.astro";
import { translations } from "../i18n/translations";

const t = translations.en;
---

<section id="hero" class="relative flex min-h-screen items-center overflow-hidden bg-bg-primary pt-20">
  <div class="absolute inset-0 grid-pattern opacity-40"></div>
  <div class="absolute inset-0">
    <ParticleMesh />
  </div>
  <div class="absolute bottom-0 left-0 right-0 h-40 bg-gradient-to-t from-[#050b18] to-transparent"></div>

  <div class="container-main relative z-10 py-16 md:py-24">
    <!-- Mobile: photo first -->
    <div class="mb-10 flex justify-center md:hidden">
      <div class="relative">
        <div class="profile-ring absolute -inset-1 rounded-full opacity-80 blur-sm"></div>
        <div class="relative rounded-full p-1">
          <div class="profile-ring absolute inset-0 rounded-full"></div>
          <img
            src="/images/profile.png"
            alt={site.name}
            width="200"
            height="200"
            class="relative h-[200px] w-[200px] rounded-full border-4 border-[#050b18] object-cover"
            loading="eager"
          />
        </div>
      </div>
    </div>

    <div class="grid items-center gap-12 lg:grid-cols-2 lg:gap-16">
      <!-- Text column -->
      <div class="reveal text-center lg:text-left">
        <!-- Available chip -->
        <div
          class="mb-6 inline-flex items-center gap-2 rounded-full border border-emerald-500/30 bg-emerald-500/10 px-4 py-1.5"
        >
          <span class="status-dot h-2 w-2 rounded-full bg-emerald-400"></span>
          <span class="text-xs font-medium text-emerald-300" data-i18n="hero.available">
            {t.hero.available}
          </span>
        </div>

        <h1
          class="text-[42px] font-extrabold leading-tight tracking-[-2px] text-white md:text-[56px] lg:text-[72px]"
        >
          {site.name}
        </h1>

        <div class="mt-4 flex justify-center lg:justify-start">
          <Typewriter />
        </div>

        <p
          class="mx-auto mt-6 max-w-[480px] text-lg text-muted lg:mx-0"
          data-i18n="hero.subtitle"
        >
          {t.hero.subtitle}
        </p>

        <div class="mt-8 flex flex-col items-center gap-4 sm:flex-row lg:justify-start">
          <a href="#projects" class="btn-primary w-full sm:w-auto" data-i18n="hero.ctaProjects">
            {t.hero.ctaProjects}
          </a>
          <a href="#contact" class="btn-secondary w-full sm:w-auto" data-i18n="hero.ctaContact">
            {t.hero.ctaContact}
          </a>
        </div>

        <!-- Stats row -->
        <div class="mt-10 flex items-center justify-center lg:justify-start">
          <div class="text-center lg:text-left">
            <p class="text-2xl font-bold text-white" data-counter={t.hero.stats[0].value}>
              {t.hero.stats[0].value}
            </p>
            <p class="text-xs uppercase tracking-wide text-muted" data-i18n-hero-stat-label="0">
              {t.hero.stats[0].label}
            </p>
          </div>
          <div class="mx-4 h-8 w-px bg-white/10 sm:mx-6"></div>
          <div class="text-center lg:text-left">
            <p class="text-2xl font-bold text-white" data-counter={t.hero.stats[1].value}>
              {t.hero.stats[1].value}
            </p>
            <p class="text-xs uppercase tracking-wide text-muted" data-i18n-hero-stat-label="1">
              {t.hero.stats[1].label}
            </p>
          </div>
          <div class="mx-4 h-8 w-px bg-white/10 sm:mx-6"></div>
          <div class="text-center lg:text-left">
            <p class="text-2xl font-bold text-white" data-counter={t.hero.stats[2].value}>
              {t.hero.stats[2].value}
            </p>
            <p class="text-xs uppercase tracking-wide text-muted" data-i18n-hero-stat-label="2">
              {t.hero.stats[2].label}
            </p>
          </div>
        </div>
      </div>

      <!-- Photo column — desktop -->
      <div class="reveal hidden justify-center md:flex" style="transition-delay: 200ms">
        <div class="relative">
          <div
            class="absolute -inset-4 rounded-full bg-gradient-to-br from-primary/20 to-secondary/20 blur-3xl"
          ></div>
          <div class="relative rounded-full p-1.5">
            <div class="profile-ring absolute inset-0 rounded-full"></div>
            <img
              src="/images/profile.png"
              alt={site.name}
              width="280"
              height="280"
              class="relative h-[280px] w-[280px] rounded-full border-4 border-[#050b18] object-cover shadow-2xl"
              loading="eager"
            />
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Scroll indicator -->
  <a
    href="#about"
    class="scroll-indicator absolute bottom-8 left-1/2 z-10 flex -translate-x-1/2 flex-col items-center gap-2 text-muted"
    aria-label="Scroll down"
  >
    <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
    </svg>
  </a>
</section>
