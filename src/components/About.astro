---
import { translations } from "../i18n/translations";

const t = translations.en;
---

<section id="about" class="section-padding bg-bg-secondary">
  <div class="container-main">
    <h2 class="section-heading reveal" data-i18n="about.title">{t.about.title}</h2>

    <div class="mt-14 grid items-start gap-12 lg:grid-cols-2 lg:gap-16">
      <!-- Text left -->
      <div class="reveal" style="transition-delay: 100ms">
        <p
          class="text-lg leading-relaxed text-muted"
          data-i18n-html="about.textHtml"
          set:html={t.about.textHtml}
        />
      </div>

      <!-- Stat cards right -->
      <div class="grid gap-6 sm:grid-cols-3 lg:grid-cols-1 lg:gap-4" data-stagger>
        {
          t.about.highlights.map((item, i) => (
            <div
              class="glass-card reveal-item p-6 text-center lg:text-left"
              style={`transition-delay: ${i * 100}ms`}
            >
              <p
                class="stat-number text-4xl font-extrabold"
                data-counter={item.value}
              >
                {item.value}
              </p>
              <p
                class="mt-2 text-sm text-muted"
                data-i18n-highlight-label={i}
              >
                {item.label}
              </p>
            </div>
          ))
        }
      </div>
    </div>
  </div>
</section>
