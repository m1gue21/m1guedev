---
import { site } from "../data/site";
---

<section id="about" class="relative py-24 sm:py-32">
  <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
    <h2 class="section-title text-3xl font-bold text-white sm:text-4xl">About</h2>

    <div class="mt-12 grid items-center gap-12 lg:grid-cols-2">
      <!-- Profile image for About section -->
      <div class="relative mx-auto lg:mx-0">
        <div
          class="absolute -inset-4 rounded-2xl bg-gradient-to-br from-primary/20 to-secondary/20 blur-2xl"
        ></div>
        <img
          src="/images/profile.png"
          alt={site.name}
          width="400"
          height="400"
          class="relative w-full max-w-sm rounded-2xl border border-white/10 object-cover shadow-2xl"
          loading="lazy"
        />
      </div>

      <div>
        <p class="text-lg leading-relaxed text-muted">
          {site.about}
        </p>

        <!-- Highlight cards -->
        <div class="mt-10 grid gap-4 sm:grid-cols-3">
          {
            site.highlights.map((item) => (
              <div class="glass-card rounded-xl p-5 text-center transition-transform hover:-translate-y-1">
                <p class="text-3xl font-bold text-primary">{item.value}</p>
                <p class="mt-1 text-sm text-muted">{item.label}</p>
              </div>
            ))
          }
        </div>
      </div>
    </div>
  </div>
</section>
