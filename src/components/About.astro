---
import { site } from "../data/site";
import { translations } from "../i18n/translations";

const t = translations.en;
---

<section id="about" class="relative py-24 sm:py-32">
  <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
    <h2 class="section-title text-3xl font-bold text-white sm:text-4xl" data-i18n="about.title">
      {t.about.title}
    </h2>

    <div class="mt-12 grid items-center gap-12 lg:grid-cols-2">
      <div class="relative mx-auto lg:mx-0">
        <div
          class="absolute -inset-4 rounded-2xl bg-gradient-to-br from-primary/20 to-secondary/20 blur-2xl"
        ></div>
        <img
          src="/images/profile.png"
          alt={site.name}
          width="400"
          height="400"
          class="relative w-full max-w-sm rounded-2xl border border-white/10 object-cover shadow-2xl"
          loading="lazy"
        />
      </div>

      <div>
        <p class="text-lg leading-relaxed text-muted" data-i18n="about.text">
          {t.about.text}
        </p>

        <div class="mt-10 grid grid-cols-3 gap-3 sm:gap-4">
          {
            t.about.highlights.map((item, i) => (
              <div class="glass-card rounded-xl p-4 text-center transition-transform hover:-translate-y-1 sm:p-5">
                <p class="text-2xl font-bold text-primary sm:text-3xl" data-counter={item.value}>
                  {item.value}
                </p>
                <p class="mt-1 text-xs text-muted sm:text-sm" data-i18n-highlight-label={i}>
                  {item.label}
                </p>
              </div>
            ))
          }
        </div>
      </div>
    </div>
  </div>
</section>
