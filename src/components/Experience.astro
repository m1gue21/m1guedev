---
import { experience } from "../data/experience";
import { translations } from "../i18n/translations";

const t = translations.en;
---

<section id="experience" class="section-padding relative">
  <div
    class="absolute inset-0 bg-[radial-gradient(ellipse_at_bottom,rgba(59,130,246,0.04)_0%,transparent_60%)]"
  ></div>

  <div class="container-main relative">
    <div class="reveal">
      <h2 class="section-heading" data-i18n="experience.title">{t.experience.title}</h2>
      <p class="mt-6 max-w-2xl text-muted" data-i18n="experience.subtitle">
        {t.experience.subtitle}
      </p>
    </div>

    <div class="relative mt-16">
      <!-- Central gradient line -->
      <div
        class="absolute left-4 top-0 bottom-0 w-0.5 bg-gradient-to-b from-primary via-secondary to-primary/20 md:left-1/2 md:-translate-x-px"
      ></div>

      <div class="space-y-10 md:space-y-12" data-stagger>
        {
          experience.map((item, index) => {
            const data = t.experience.items[item.id];
            const isEven = index % 2 === 0;
            return (
              <div
                class={`reveal-item relative flex items-center ${isEven ? "md:flex-row-reverse" : ""}`}
                style={`transition-delay: ${index * 100}ms`}
              >
                <!-- Dot -->
                <div class="absolute left-4 z-10 -translate-x-1/2 rounded-full timeline-dot md:left-1/2"></div>

                <!-- Connection line to card -->
                <div
                  class={`absolute top-1/2 hidden h-px w-8 -translate-y-1/2 bg-gradient-to-r from-primary/50 to-secondary/50 md:block ${
                    isEven
                      ? "left-1/2 ml-2 bg-gradient-to-l"
                      : "right-1/2 mr-2 ml-auto bg-gradient-to-r"
                  }`}
                  style={isEven ? "left: calc(50% + 8px); width: 32px;" : "right: calc(50% + 8px); width: 32px; left: auto;"}
                ></div>

                <!-- Spacer -->
                <div class="hidden w-1/2 md:block"></div>

                <!-- Card -->
                <div class={`w-full pl-12 md:w-1/2 md:pl-0 ${isEven ? "md:pr-12 md:text-right" : "md:pl-12"}`}>
                  <div class="experience-card glass-card p-6">
                    <span class="date-pill">{item.period}</span>
                    <h3
                      class="mt-3 text-lg font-bold text-white"
                      data-i18n={`experience.items.${item.id}.company`}
                    >
                      {data.company}
                    </h3>
                    <p
                      class="mt-1 text-sm font-medium text-secondary"
                      data-i18n={`experience.items.${item.id}.role`}
                    >
                      {data.role}
                    </p>
                    <p
                      class="mt-3 text-sm text-muted"
                      data-i18n={`experience.items.${item.id}.impact`}
                    >
                      {data.impact}
                    </p>
                  </div>
                </div>
              </div>
            );
          })
        }
      </div>
    </div>
  </div>
</section>
