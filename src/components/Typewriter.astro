<p class="mt-4 text-xl font-light text-muted sm:text-2xl md:text-3xl">
  <span id="typewriter-text" class="text-secondary"></span
  ><span class="typewriter-cursor text-primary">|</span>
</p>

<script>
  import {
    translations,
    DEFAULT_LOCALE,
    STORAGE_KEY,
    type Locale,
  } from "../i18n/translations";

  let roleIndex = 0;
  let charIndex = 0;
  let isDeleting = false;
  let pauseCounter = 0;
  let timeoutId: ReturnType<typeof setTimeout>;

  const TYPE_SPEED = 80;
  const DELETE_SPEED = 40;
  const PAUSE_END = 30;
  const PAUSE_START = 12;

  function getLocale(): Locale {
    const stored = localStorage.getItem(STORAGE_KEY) as Locale | null;
    return stored === "es" ? "es" : DEFAULT_LOCALE;
  }

  function getRoles(): string[] {
    return translations[getLocale()].hero.roles;
  }

  function reset() {
    roleIndex = 0;
    charIndex = 0;
    isDeleting = false;
    pauseCounter = 0;
    clearTimeout(timeoutId);
  }

  function tick() {
    const textEl = document.getElementById("typewriter-text");
    if (!textEl) return;

    const roles = getRoles();
    const currentRole = roles[roleIndex] ?? "";

    if (!isDeleting && pauseCounter === 0) {
      textEl.textContent = currentRole.substring(0, charIndex + 1);
      charIndex++;
      if (charIndex === currentRole.length) {
        isDeleting = true;
        pauseCounter = PAUSE_END;
      }
    } else if (isDeleting && pauseCounter === 0) {
      textEl.textContent = currentRole.substring(0, charIndex - 1);
      charIndex--;
      if (charIndex === 0) {
        isDeleting = false;
        roleIndex = (roleIndex + 1) % roles.length;
        pauseCounter = PAUSE_START;
      }
    }

    if (pauseCounter > 0) pauseCounter--;

    timeoutId = setTimeout(tick, isDeleting ? DELETE_SPEED : TYPE_SPEED);
  }

  function start() {
    reset();
    tick();
  }

  start();
  window.addEventListener("localechange", start);
</script>
