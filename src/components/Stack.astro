---
import { stackData } from "../data/stack";
import TechIcon from "./TechIcon.astro";
---

<section id="stack" class="relative py-24 sm:py-32">
  <!-- Subtle background gradient -->
  <div
    class="absolute inset-0 bg-[radial-gradient(ellipse_at_top,rgba(6,182,212,0.05)_0%,transparent_60%)]"
  ></div>

  <div class="relative mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
    <h2 class="section-title text-3xl font-bold text-white sm:text-4xl">
      Tech Stack
    </h2>
    <p class="mt-4 max-w-2xl text-muted">
      Technologies and tools I use to build modern, scalable applications.
    </p>

    <div class="mt-12 space-y-12">
      {
        stackData.map((category) => (
          <div>
            <h3 class="mb-6 text-sm font-semibold tracking-widest text-secondary uppercase">
              {category.category}
            </h3>
            <div class="grid grid-cols-2 gap-4 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-6">
              {category.items.map((tech) => (
                <div class="glass-card group flex flex-col items-center gap-3 rounded-xl p-5 transition-all hover:border-primary/30 hover:shadow-lg hover:shadow-primary/10">
                  <TechIcon icon={tech.icon} name={tech.name} />
                  <span class="text-center text-xs font-medium text-muted group-hover:text-white">
                    {tech.name}
                  </span>
                </div>
              ))}
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>
