---
import { stackData } from "../data/stack";
import SimpleIcon from "./SimpleIcon.astro";
import { translations } from "../i18n/translations";

const t = translations.en;
---

<section id="stack" class="relative py-24 sm:py-32">
  <div
    class="absolute inset-0 bg-[radial-gradient(ellipse_at_top,rgba(6,182,212,0.05)_0%,transparent_60%)]"
  ></div>

  <div class="relative mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
    <h2 class="section-title text-3xl font-bold text-white sm:text-4xl" data-i18n="stack.title">
      {t.stack.title}
    </h2>
    <p class="mt-4 max-w-2xl text-muted" data-i18n="stack.subtitle">
      {t.stack.subtitle}
    </p>

    <div class="mt-12 space-y-12">
      {
        stackData.map((category) => (
          <div>
            <h3
              class="mb-6 text-sm font-semibold tracking-widest text-secondary uppercase"
              data-i18n={`stack.categories.${category.id}`}
            >
              {t.stack.categories[category.id as keyof typeof t.stack.categories]}
            </h3>
            <div class="grid grid-cols-3 gap-3 sm:grid-cols-4 md:grid-cols-5 lg:grid-cols-6 sm:gap-4">
              {category.items.map((tech) => (
                <div class="glass-card stack-card group flex flex-col items-center gap-3 rounded-xl p-4 sm:p-5">
                  <SimpleIcon slug={tech.slug} color={tech.color} name={tech.name} size={40} />
                  <span class="text-center text-xs font-medium text-muted group-hover:text-white transition-colors">
                    {tech.name}
                  </span>
                </div>
              ))}
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>
