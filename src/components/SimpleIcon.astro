---
interface Props {
  slug: string;
  color: string;
  name: string;
  size?: number;
}

const { slug, color, name, size = 40 } = Astro.props;
const whiteUrl = `https://cdn.simpleicons.org/${slug}/ffffff`;
const brandUrl = `https://cdn.simpleicons.org/${slug}/${color}`;
---

<div class="relative flex items-center justify-center" style={`width:${size}px;height:${size}px`}>
  <img
    src={whiteUrl}
    alt={name}
    width={size}
    height={size}
    loading="lazy"
    class="absolute inset-0 m-auto transition-opacity duration-300 group-hover:opacity-0"
  />
  <img
    src={brandUrl}
    alt=""
    aria-hidden="true"
    width={size}
    height={size}
    loading="lazy"
    class="absolute inset-0 m-auto opacity-0 transition-opacity duration-300 group-hover:opacity-100"
  />
</div>
