---
interface Props {
  slug: string;
  color: string;
  name: string;
  size?: number;
  local?: string;
}

const { slug, color, name, size = 40, local } = Astro.props;
const whiteUrl = local ?? `https://cdn.simpleicons.org/${slug}/ffffff`;
const brandUrl = local ?? `https://cdn.simpleicons.org/${slug}/${color}`;
---

<div
  class="relative flex items-center justify-center"
  style={`width:${size}px;height:${size}px;--icon-color:#${color}`}
>
  <img
    src={whiteUrl}
    alt={name}
    width={size}
    height={size}
    loading="lazy"
    class={`absolute inset-0 m-auto transition-all duration-300 group-hover:scale-110 ${local ? "" : "group-hover:opacity-0"}`}
  />
  {
    !local && (
      <img
        src={brandUrl}
        alt=""
        aria-hidden="true"
        width={size}
        height={size}
        loading="lazy"
        class="absolute inset-0 m-auto opacity-0 transition-all duration-300 group-hover:opacity-100 group-hover:scale-110"
      />
    )
  }
</div>
