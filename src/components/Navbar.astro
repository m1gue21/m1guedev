---
import { site } from "../data/site";
import { translations } from "../i18n/translations";

const t = translations.en;
---

<header id="navbar" class="navbar-base fixed top-0 left-0 right-0 z-50 transition-all duration-300">
  <nav class="container-main flex items-center justify-between py-4">
    <a href="#" class="logo-gradient text-lg font-bold tracking-tight">
      {site.shortName}
    </a>

    <!-- Desktop -->
    <div class="hidden items-center gap-8 md:flex">
      <ul class="flex items-center gap-8">
        {
          t.nav.links.map((label, i) => (
            <li>
              <a
                href={site.navHrefs[i]}
                class="nav-link text-sm font-medium"
                data-i18n={`nav.links.${i}`}
              >
                {label}
              </a>
            </li>
          ))
        }
      </ul>

      <div class="lang-pill">
        <button type="button" data-lang-btn="en" aria-pressed="true" class="text-secondary">
          EN
        </button>
        <button type="button" data-lang-btn="es" aria-pressed="false" class="text-muted">
          ES
        </button>
      </div>
    </div>

    <!-- Mobile -->
    <div class="flex items-center gap-3 md:hidden">
      <div class="lang-pill">
        <button type="button" data-lang-btn="en" aria-pressed="true" class="text-secondary">
          EN
        </button>
        <button type="button" data-lang-btn="es" aria-pressed="false" class="text-muted">
          ES
        </button>
      </div>
      <button
        id="menu-toggle"
        class="flex h-10 w-10 items-center justify-center rounded-lg border border-white/10"
        aria-label="Toggle menu"
        aria-expanded="false"
      >
        <div id="hamburger" class="hamburger flex flex-col gap-1.5">
          <span class="hamburger-line line-1"></span>
          <span class="hamburger-line line-2"></span>
          <span class="hamburger-line line-3"></span>
        </div>
      </button>
    </div>
  </nav>

  <!-- Mobile overlay menu -->
  <div
    id="mobile-menu"
    class="mobile-overlay fixed inset-0 top-[65px] z-40 hidden md:hidden"
  >
    <ul class="flex flex-col items-center justify-center gap-2 px-6 pt-12">
      {
        t.nav.links.map((label, i) => (
          <li class="w-full">
            <a
              href={site.navHrefs[i]}
              class="mobile-nav-link block rounded-xl px-6 py-4 text-center text-lg font-medium text-muted transition-colors hover:bg-white/5 hover:text-white"
              data-i18n={`nav.links.${i}`}
            >
              {label}
            </a>
          </li>
        ))
      }
    </ul>
  </div>
</header>
