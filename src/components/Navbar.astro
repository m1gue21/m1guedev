---
import { site } from "../data/site";
import { translations } from "../i18n/translations";

const t = translations.en;
---

<header id="navbar" class="fixed top-0 left-0 right-0 z-50 transition-all duration-300">
  <nav class="mx-auto flex max-w-6xl items-center justify-between px-4 py-4 sm:px-6 lg:px-8">
    <a
      href="#"
      class="text-lg font-bold tracking-tight text-white transition-colors hover:text-primary"
    >
      {site.shortName}
    </a>

    <!-- Desktop nav -->
    <div class="hidden items-center gap-6 md:flex">
      <ul class="flex items-center gap-8">
        {
          t.nav.links.map((label, i) => (
            <li>
              <a
                href={site.navHrefs[i]}
                class="nav-link text-sm font-medium text-muted transition-colors hover:text-white"
                data-i18n={`nav.links.${i}`}
              >
                {label}
              </a>
            </li>
          ))
        }
      </ul>

      <!-- Language toggle -->
      <div class="flex items-center gap-1 rounded-lg border border-white/10 p-1">
        <button
          type="button"
          data-lang-btn="en"
          aria-pressed="true"
          class="rounded-md border border-primary/50 bg-primary/20 px-2.5 py-1 text-xs font-semibold text-primary transition-colors"
        >
          EN
        </button>
        <button
          type="button"
          data-lang-btn="es"
          aria-pressed="false"
          class="rounded-md border border-white/10 px-2.5 py-1 text-xs font-semibold text-muted transition-colors"
        >
          ES
        </button>
      </div>
    </div>

    <!-- Mobile: lang + menu -->
    <div class="flex items-center gap-2 md:hidden">
      <div class="flex items-center gap-1 rounded-lg border border-white/10 p-0.5">
        <button
          type="button"
          data-lang-btn="en"
          aria-pressed="true"
          class="rounded px-2 py-1 text-xs font-semibold bg-primary/20 text-primary"
        >
          EN
        </button>
        <button
          type="button"
          data-lang-btn="es"
          aria-pressed="false"
          class="rounded px-2 py-1 text-xs font-semibold text-muted"
        >
          ES
        </button>
      </div>
      <button
        id="menu-toggle"
        class="flex h-10 w-10 items-center justify-center rounded-lg border border-white/10 text-white"
        aria-label="Toggle menu"
        aria-expanded="false"
      >
        <svg id="menu-icon-open" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
        <svg id="menu-icon-close" class="hidden h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>
  </nav>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden border-t border-white/10 bg-navy/95 backdrop-blur-xl md:hidden">
    <ul class="flex flex-col gap-1 px-4 py-4">
      {
        t.nav.links.map((label, i) => (
          <li>
            <a
              href={site.navHrefs[i]}
              class="mobile-nav-link block rounded-lg px-4 py-3 text-sm font-medium text-muted transition-colors hover:bg-white/5 hover:text-white"
              data-i18n={`nav.links.${i}`}
            >
              {label}
            </a>
          </li>
        ))
      }
    </ul>
  </div>
</header>
