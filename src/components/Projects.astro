---
import { projects } from "../data/projects";
import { getTechIcon, hexToRgba } from "../utils/icons";
import { translations } from "../i18n/translations";

const t = translations.en;
---

<section id="projects" class="section-padding bg-bg-secondary">
  <div class="container-main">
    <div class="reveal">
      <h2 class="section-heading" data-i18n="projects.title">{t.projects.title}</h2>
      <p class="mt-6 max-w-2xl text-muted" data-i18n="projects.subtitle">
        {t.projects.subtitle}
      </p>
    </div>

    <div class="mt-14 grid grid-cols-1 gap-6 md:grid-cols-2" data-stagger>
      {
        projects.map((project, i) => {
          const data = t.projects.items[project.id];
          return (
            <article
              class="project-card glass-card reveal-item relative flex flex-col"
              style={`transition-delay: ${i * 100}ms`}
            >
              <!-- Accent bar -->
              <div class={`h-2 bg-gradient-to-r ${project.accentBar}`}></div>

              <div class="relative flex flex-1 flex-col p-6 pt-8">
                <!-- Impact number top right -->
                <p
                  class="absolute right-5 top-5 max-w-[120px] text-right text-lg font-extrabold leading-tight text-gradient sm:text-xl"
                  data-i18n={`projects.items.${project.id}.impact`}
                >
                  {data.impact}
                </p>

                <!-- Badge -->
                <span
                  class="badge-text mb-4 inline-block w-fit rounded-full bg-secondary/15 px-3 py-1 text-secondary ring-1 ring-secondary/30"
                  data-i18n="projects.badge"
                >
                  {t.projects.badge}
                </span>

                <h3
                  class="text-xl font-bold text-white"
                  data-i18n={`projects.items.${project.id}.name`}
                >
                  {data.name}
                </h3>
                <p
                  class="badge-text mt-1 text-text-muted"
                  data-i18n={`projects.items.${project.id}.subtitle`}
                >
                  {data.subtitle}
                </p>

                <p
                  class="project-desc mt-4 flex-1 text-sm text-muted"
                  data-i18n={`projects.items.${project.id}.description`}
                >
                  {data.description}
                </p>

                <div class="mt-5 flex flex-wrap gap-2">
                  {project.stack.map((tech) => {
                    const icon = getTechIcon(tech);
                    const bg = hexToRgba(icon.color.length === 6 ? icon.color : "3b82f6", 0.15);
                    return (
                      <span
                        class="inline-flex items-center gap-1.5 rounded-full px-2.5 py-1 text-xs font-medium text-white"
                        style={`background:${bg};border:1px solid ${hexToRgba(icon.color.length === 6 ? icon.color : "3b82f6", 0.25)}`}
                      >
                        <img
                          src={`https://cdn.simpleicons.org/${icon.slug}/${icon.color}`}
                          alt=""
                          width="14"
                          height="14"
                          class="h-3.5 w-3.5"
                          loading="lazy"
                        />
                        {tech}
                      </span>
                    );
                  })}
                </div>
              </div>
            </article>
          );
        })
      }
    </div>
  </div>
</section>
