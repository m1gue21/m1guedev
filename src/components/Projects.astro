---
import { projects } from "../data/projects";
---

<section id="projects" class="relative py-24 sm:py-32">
  <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
    <h2 class="section-title text-3xl font-bold text-white sm:text-4xl">
      Projects
    </h2>
    <p class="mt-4 max-w-2xl text-muted">
      Selected professional projects with real-world impact.
    </p>

    <div class="mt-12 grid gap-6 md:grid-cols-2">
      {
        projects.map((project) => (
          <article class="glass-card group flex flex-col rounded-2xl p-6 transition-all hover:border-primary/30 hover:shadow-xl hover:shadow-primary/10 sm:p-8">
            <div class="mb-4 flex items-start justify-between gap-4">
              <div>
                <h3 class="text-xl font-bold text-white group-hover:text-primary transition-colors">
                  {project.name}
                </h3>
                <p class="text-sm text-secondary">{project.subtitle}</p>
              </div>
              <span class="shrink-0 rounded-full bg-primary/10 px-3 py-1 text-xs font-medium text-primary">
                Professional Project
              </span>
            </div>

            <p class="mb-6 flex-1 text-sm leading-relaxed text-muted">
              {project.description}
            </p>

            <div class="flex flex-wrap gap-2">
              {project.stack.map((tech) => (
                <span class="rounded-md bg-white/5 px-2.5 py-1 text-xs font-medium text-muted border border-white/10">
                  {tech}
                </span>
              ))}
            </div>
          </article>
        ))
      }
    </div>
  </div>
</section>
