---
import { projects } from "../data/projects";
import SimpleIcon from "./SimpleIcon.astro";
import { getTechIcon } from "../utils/icons";
import { translations } from "../i18n/translations";

const t = translations.en;
---

<section id="projects" class="relative py-24 sm:py-32">
  <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
    <h2 class="section-title text-3xl font-bold text-white sm:text-4xl" data-i18n="projects.title">
      {t.projects.title}
    </h2>
    <p class="mt-4 max-w-2xl text-muted" data-i18n="projects.subtitle">
      {t.projects.subtitle}
    </p>

    <!-- Single column on mobile, 2 cols on md+ -->
    <div class="mt-12 grid grid-cols-1 gap-6 md:grid-cols-2">
      {
        projects.map((project) => {
          const data = t.projects.items[project.id];
          return (
            <article class="project-card glass-card group flex flex-col overflow-hidden rounded-2xl">
              <!-- Gradient header -->
              <div class={`bg-gradient-to-r ${project.gradient} px-6 py-5 sm:px-8`}>
                <div class="flex items-start justify-between gap-4">
                  <div>
                    <h3
                      class="text-xl font-bold text-white"
                      data-i18n={`projects.items.${project.id}.name`}
                    >
                      {data.name}
                    </h3>
                    <p
                      class="text-sm text-white/80"
                      data-i18n={`projects.items.${project.id}.subtitle`}
                    >
                      {data.subtitle}
                    </p>
                  </div>
                  <span
                    class="shrink-0 rounded-full bg-secondary/20 px-3 py-1 text-xs font-semibold text-secondary ring-1 ring-secondary/40"
                    data-i18n="projects.badge"
                  >
                    {t.projects.badge}
                  </span>
                </div>
              </div>

              <div class="flex flex-1 flex-col p-6 sm:p-8">
                <!-- Impact metric -->
                <p
                  class="mb-4 text-lg font-bold text-secondary"
                  data-i18n={`projects.items.${project.id}.impact`}
                >
                  {data.impact}
                </p>

                <p
                  class="mb-6 flex-1 text-sm leading-relaxed text-muted"
                  data-i18n={`projects.items.${project.id}.description`}
                >
                  {data.description}
                </p>

                <div class="flex flex-wrap gap-2">
                  {project.stack.map((tech) => {
                    const icon = getTechIcon(tech);
                    return (
                      <span class="inline-flex items-center gap-1.5 rounded-md border border-white/10 bg-white/5 px-2 py-1 text-xs font-medium text-muted">
                        <img
                          src={`https://cdn.simpleicons.org/${icon.slug}/${icon.color}`}
                          alt=""
                          width="14"
                          height="14"
                          class="h-3.5 w-3.5"
                          loading="lazy"
                        />
                        {tech}
                      </span>
                    );
                  })}
                </div>
              </div>
            </article>
          );
        })
      }
    </div>
  </div>
</section>
